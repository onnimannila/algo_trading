{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run execution (module)",
      "type": "python",
      "request": "launch",
      "module": "main.execution",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "env": { "PYTHONUNBUFFERED": "1" }
    },
    {
      "name": "Run execution (file with PYTHONPATH)",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/main/execution.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "env": { "PYTHONPATH": "${workspaceFolder}", "PYTHONUNBUFFERED": "1" }
    }
  ]
}
